---
interface Props {
  name: string;
  skills: string[];
  wide?: boolean;
}

const { name, skills, wide = false } = Astro.props;

interface SkillMeta {
  logo?: string;
  color: string;
  lightBg?: boolean; // logo color becomes dark on light backgrounds
  url?: string;
}

const skillMeta: Record<string, SkillMeta> = {
