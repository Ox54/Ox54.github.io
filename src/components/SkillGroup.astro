  'LangChain':    { logo: 'langchain',    color: '1c3c3c', url: 'https://www.langchain.com/' },
  'LangGraph':    { logo: 'langchain',    color: '1c3c3c', url: 'https://langchain-ai.github.io/langgraph/' },
  'PydanticAI':   { logo: 'pydantic',     color: 'E92063', url: 'https://ai.pydantic.dev/' },
  'ChatGPT':      { logo: 'openai',       color: '412991', url: 'https://openai.com/' },
  'Claude':       { logo: 'anthropic',    color: 'D97757', url: 'https://anthropic.com/claude' },
  'Mistral':      { logo: 'mistral',      color: 'FF7000', url: 'https://mistral.ai/' },
  'RAG':          {                        color: '4a5568', url: 'https://python.langchain.com/docs/concepts/rag/' },
  'logfire':      { logo: 'pydantic',     color: 'FF4700', url: 'https://pydantic.dev/logfire' },
  'XGBoost':      {                        color: '189AB4', url: 'https://xgboost.readthedocs.io/' },
  'SKLearn':      { logo: 'scikitlearn',  color: 'F7931E', lightBg: true, url: 'https://scikit-learn.org/' },
  'PyTorch':      { logo: 'pytorch',      color: 'EE4C2C', url: 'https://pytorch.org/' },
  'Hugging Face': { logo: 'huggingface',  color: 'FF9D00', lightBg: true, url: 'https://huggingface.co/' },

  // Python
  'FastAPI':      { logo: 'fastapi',      color: '009688', url: 'https://fastapi.tiangolo.com/' },
  'Flask':        { logo: 'flask',        color: '000000', url: 'https://flask.palletsprojects.com/' },
  'Pydantic':     { logo: 'pydantic',     color: 'E92063', url: 'https://docs.pydantic.dev/' },
  'SQLModel':     { logo: 'fastapi',      color: '009688', url: 'https://sqlmodel.tiangolo.com/' },
  'SQLAlchemy':   {                        color: 'D71F00', url: 'https://www.sqlalchemy.org/' },
  'Alembic':      {                        color: '6BA539', url: 'https://alembic.sqlalchemy.org/' },
  'Click':        {                        color: '000000', url: 'https://click.palletsprojects.com/' },
  'Typer':        { logo: 'fastapi',      color: '009688', url: 'https://typer.tiangolo.com/' },
  'Pandas':       { logo: 'pandas',       color: '150458', url: 'https://pandas.pydata.org/' },
  'Numpy':        { logo: 'numpy',        color: '013243', url: 'https://numpy.org/' },
  'Streamlit':    { logo: 'streamlit',    color: 'FF4B4B', url: 'https://streamlit.io/' },
  'Rich':         {                        color: '009b55', url: 'https://rich.readthedocs.io/' },
  'Plotly':       { logo: 'plotly',       color: '3F4F75', url: 'https://plotly.com/python/' },
  'Spark':        { logo: 'apachespark',  color: 'E25A1C', url: 'https://spark.apache.org/' },
  'Dask':         {                        color: 'ef8336', url: 'https://www.dask.org/' },
  'Rust / PyO3':  { logo: 'rust',         color: 'CE422B', url: 'https://pyo3.rs/' },

  // Frontend
