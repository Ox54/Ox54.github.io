function badgeUrl(skill: string): string {
  const meta = skillMeta[skill] ?? { color: '4a5568' };
  const label = skill
    .replace(/_/g, '__')
    .replace(/-/g, '--')
    .replace(/ /g, '_')
    .replace(/\//g, '%2F');
  let url = `https://img.shields.io/badge/${label}-${meta.color}?style=for-the-badge`;
  if (meta.logo) {
    url += `&logo=${meta.logo}&logoColor=${meta.lightBg ? '333' : 'white'}`;
  }
  return url;
}
---
<div class:list={['skill-group', { wide }]}>
  <h4>{name}</h4>
  <div class="skill-tags">
    {skills.map(skill => {
      const url = skillMeta[skill]?.url;
      const img = <img src={badgeUrl(skill)} alt={skill} loading="lazy" height="26" />;
      return url
        ? <a href={url} target="_blank" rel="noopener noreferrer">{img}</a>
        : img;
    })}
  </div>
</div>
