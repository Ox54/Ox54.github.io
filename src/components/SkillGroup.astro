  'Ant Design':   { logo: 'antdesign',    color: '0170FE', url: 'https://ant.design/' },
  'Angular':      { logo: 'angular',      color: 'DD0031', url: 'https://angular.dev/' },

  // Databases
  'PostgreSQL':   { logo: 'postgresql',   color: '4169E1', url: 'https://www.postgresql.org/' },
  'Redshift':     { logo: 'amazonredshift', color: '8C4FFF', url: 'https://aws.amazon.com/redshift/' },
  'MongoDB':      { logo: 'mongodb',      color: '47A248', url: 'https://www.mongodb.com/' },
  'Redis':        { logo: 'redis',        color: 'DC382D', url: 'https://redis.io/' },
  'Elasticsearch':{ logo: 'elasticsearch',color: '005571', url: 'https://www.elastic.co/elasticsearch' },
