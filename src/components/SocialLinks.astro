---
/** Icon row for profiles and contact using shields.io for-the-badge style. */
export type SocialLink = {
	href: string;
	label: string;
	iconUrl: string;
	/** Badge height in CSS pixels (width is auto) */
	size?: number;
};

const defaultLinks: SocialLink[] = [
	{
		href: 'https://www.linkedin.com/in/taylor-roberts-3a0467108/',
		label: 'LinkedIn',
		iconUrl: 'https://img.shields.io/badge/LinkedIn-0077B5?style=for-the-badge&logo=linkedin&logoColor=white',
		size: 28,
	},
	{
		href: 'https://github.com/IVIyg0t',
		label: 'GitHub',
		iconUrl: 'https://img.shields.io/badge/GitHub-181717?style=for-the-badge&logo=github&logoColor=white',
		size: 28,
	},
	{
		href: 'https://github.com/syn54x',
		label: 'GitHub (Open Source)',
		iconUrl: 'https://img.shields.io/badge/syn54x-181717?style=for-the-badge&logo=github&logoColor=white',
		size: 28,
	},
	{
		href: 'mailto:mjtaylorroberts@gmail.com',
		label: 'Email',
		iconUrl: 'https://img.shields.io/badge/Email-EA4335?style=for-the-badge&logo=gmail&logoColor=white',
		size: 28,
	},
	{
		href: 'tel:276-591-7908',
		label: 'Phone',
		iconUrl: 'https://img.shields.io/badge/Phone-555555?style=for-the-badge&logoColor=white',
		size: 28,
	},
];

type Props = {
	links?: SocialLink[];
};

const { links = defaultLinks } = Astro.props as Props;
---

<nav class="social-links" aria-label="Social and contact links">
	<ul>
		{
			links.map(({ href, label, iconUrl, size = 28 }) => {
				const isExternal = href.startsWith('http');
				return (
					<li>
						<a
							href={href}
							aria-label={label}
							style={`--badge-height: ${size}px`}
							target={isExternal ? '_blank' : undefined}
							rel={isExternal ? 'noopener noreferrer' : undefined}
						>
							<img src={iconUrl} alt="" height={size} loading="lazy" decoding="async" />
						</a>
					</li>
				);
			})
		}
	</ul>
</nav>

<style>
	.social-links {
		margin: 0.5rem 0 1.25rem;
	}

	.social-links ul {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		line-height: 0;
		border-radius: 4px;
		overflow: hidden;
		transition: opacity 0.15s ease, box-shadow 0.15s ease;
	}

	.social-links a:hover {
		opacity: 0.85;
	}

	.social-links a:focus-visible {
		outline: 2px solid var(--accent, #0d47a1);
		outline-offset: 2px;
	}

	.social-links img {
		display: block;
		height: var(--badge-height, 28px);
		width: auto;
	}
</style>
